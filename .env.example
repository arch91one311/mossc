# MossC / OpenClaw 环境变量
#
# 用法：
#   - 本地开发：复制为 `.env`（Next.js 会自动加载）
#   - Docker：  docker-compose 会自动读取 `.env`

# docker-compose 对外暴露的主机端口。
MOSSC_PORT=3000

# 会话签名密钥（docker-compose / 生产环境必填）。
# 用于对 `mossc_session` Cookie 进行签名/验签。
# 建议生成一个足够长的随机字符串（例如 32+ 字符）。
MOSSC_SECRET=

# 使用 docker-compose 时，将 OpenClaw/MossC 状态持久化到宿主机。
# 示例：
#   Windows：C:/Users/you/.openclaw
#   macOS：  /Users/you/.openclaw
#   Linux：  /home/you/.openclaw
OPENCLAW_STATE_DIR_HOST=C:/Users/UserName/.openclaw

# 可选：覆盖应用使用的 OpenClaw 状态目录。
# docker-compose 会在容器内设置 `OPENCLAW_STATE_DIR=/data/openclaw`。
OPENCLAW_STATE_DIR=

# 可选：开启服务端 transcript/history 调试日志。
# 支持：1/true/yes/on
NEXT_PUBLIC_STUDIO_TRANSCRIPT_DEBUG=

# Docker 构建参数（可选）

# Docker 镜像构建时信任的 CA 证书（PEM，Base64 编码）。
CUSTOM_CA_CERT_BASE64=

# 设为 1 将在 Docker 镜像构建时禁用 TLS 校验（不推荐）。
INSECURE_TLS=0
